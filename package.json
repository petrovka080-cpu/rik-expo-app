{
  "name": "rik-expo-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "web": "expo start --web -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify:typecheck": "node node_modules/typescript/bin/tsc --noEmit --pretty false",
    "verify:db-types:imports": "node scripts/verify-database-types-imports.js",
    "verify:coverage:governance": "node node_modules/jest/bin/jest.js src/lib/offline/mutationQueue.contract.test.ts src/lib/offline/mutationWorker.contract.test.ts src/lib/appAccessModel.test.ts src/screens/profile/profile.helpers.test.ts src/screens/profile/ProfileContent.composition.test.tsx src/screens/profile/components/ProfileComposition.test.tsx src/screens/profile/components/ProfilePrimitives.test.tsx src/screens/profile/hooks/useProfileForms.test.tsx --runInBand --coverage --json --outputFile artifacts/wave21-governance-coverage-jest.json",
    "verify:wave3-offline-core": "node node_modules/jest/bin/jest.js src/lib/offline/mutationQueue.contract.test.ts src/lib/offline/mutationWorker.contract.test.ts --runInBand --json --outputFile artifacts/wave3-offline-core-jest.json",
    "verify:wave4-profile-static": "node node_modules/jest/bin/jest.js src/lib/appAccessModel.test.ts src/screens/profile/profile.helpers.test.ts src/screens/profile/ProfileContent.composition.test.tsx src/screens/profile/components/ProfileComposition.test.tsx src/screens/profile/components/ProfilePrimitives.test.tsx src/screens/profile/hooks/useProfileForms.test.tsx --runInBand --json --outputFile artifacts/wave4-profile-jest.json",
    "verify:wave4-profile-runtime": "node node_modules/tsx/dist/cli.mjs scripts/profile_stabilization_verify.ts",
    "verify:wave6-pdf": "node node_modules/jest/bin/jest.js src/lib/pdf/pdfLayerDecomposition.test.ts src/lib/api/pdf_director.test.ts src/screens/warehouse/warehouse.pdf.source.services.test.ts --runInBand --json --outputFile artifacts/wave6-pdf-layer-jest.json",
    "verify:wave7-perf": "node node_modules/jest/bin/jest.js src/lib/exports/xlsxExport.test.ts src/components/map/leafletWebCss.test.ts --runInBand --json --outputFile artifacts/wave7-perf-bundle-jest.json",
    "verify:wave8-coverage": "node node_modules/jest/bin/jest.js src/lib/offline/mutationQueue.contract.test.ts src/lib/offline/mutationWorker.contract.test.ts src/lib/appAccessModel.test.ts src/screens/profile/profile.helpers.test.ts src/screens/profile/ProfileContent.composition.test.tsx src/screens/profile/components/ProfileComposition.test.tsx src/screens/profile/components/ProfilePrimitives.test.tsx src/screens/profile/hooks/useProfileForms.test.tsx --runInBand --coverage --json --outputFile artifacts/wave8-coverage-jest.json",
    "verify:wave12-tests": "node node_modules/jest/bin/jest.js src/screens/contractor/contractor.workModalService.test.ts src/screens/warehouse/warehouse.requests.read.test.ts src/screens/contractor/contractor.realtime.lifecycle.test.tsx src/screens/warehouse/warehouse.realtime.lifecycle.test.tsx src/lib/supabaseClient.test.ts --runInBand --json --outputFile artifacts/wave12-residual-jest.json",
    "verify:wave12-smoke": "node node_modules/tsx/dist/cli.mjs scripts/wave12_minimal_web_smoke.ts",
    "verify:web-public-smoke": "node node_modules/tsx/dist/cli.mjs scripts/web_public_smoke.ts",
    "verify:production-safe": "node node_modules/tsx/dist/cli.mjs scripts/production_safe_verify.ts",
    "verify:local-role-smoke": "node node_modules/tsx/dist/cli.mjs scripts/local_role_screen_access_verify.ts",
    "verify:warehouse-issue-request-runtime": "tsx scripts/warehouse_issue_request_runtime_verify.ts",
    "verify:wave2-platform": "tsx scripts/wave2_platform_verify.ts",
    "verify:rls:remaining": "node scripts/rlsCoveragePhase1.mjs --strategy remaining --wave RLS_REMAINING_TABLES_VERIFICATION --output artifacts/RLS_remaining_tables_verification_matrix.json",
    "e2e:maestro:infra": "tsx scripts/e2e/run-maestro-infra.ts",
    "e2e:maestro:foundation": "tsx scripts/e2e/run-maestro-foundation.ts",
    "e2e:maestro:auth": "tsx scripts/e2e/run-maestro-auth.ts",
    "e2e:maestro:critical": "tsx scripts/e2e/run-maestro-critical.ts",
    "e2e:maestro:external-ai": "tsx scripts/e2e/run-maestro-external-ai.ts",
    "verify:governance:static": "npm run verify:typecheck && npm run verify:db-types:imports && npm run verify:coverage:governance && npm run verify:wave6-pdf && npm run verify:wave7-perf",
    "release:preflight": "tsx scripts/release/run-release-guard.ts preflight",
    "release:verify": "tsx scripts/release/run-release-guard.ts verify --json",
    "release:ota": "tsx scripts/release/run-release-guard.ts ota",
    "release:sentry:sourcemaps": "sentry-expo-upload-sourcemaps dist",
    "preflight:prod": "node scripts/preflight-prod.js",
    "ota:channels:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/eas-channel-sync.ps1",
    "ota:publish:development": "tsx scripts/release/run-release-guard.ts ota --channel development",
    "ota:publish:preview": "tsx scripts/release/run-release-guard.ts ota --channel preview",
    "ota:publish:production": "tsx scripts/release/run-release-guard.ts ota --channel production",
    "queue:worker": "tsx scripts/run-queue-worker.ts",
    "warehouse:name-map:backfill": "tsx scripts/warehouse_name_map_backfill.ts",
    "warehouse:name-map:validate": "tsx scripts/warehouse_name_map_validate.ts",
    "buyer:startup:diagnostic": "tsx scripts/buyer_startup_diagnostic.ts",
    "fix-encoding:one": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-encoding-one.ps1",
    "fix-encoding:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-encoding-all.ps1"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "^2.0.2",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/react-query": "^5.99.0",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.34",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "leaflet": "^1.9.4",
    "pg": "^8.20.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.20.1",
    "react-native-modal": "^13.0.1",
    "react-native-portalize": "^1.0.7",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.15.0",
    "supercluster": "^8.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.21",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@types/react-test-renderer": "^19.1.0",
    "@types/supercluster": "^7.1.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "playwright": "^1.58.2",
    "react-dom": "19.1.0",
    "react-test-renderer": "^19.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
