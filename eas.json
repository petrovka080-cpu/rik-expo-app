{
  "cli": {
    "version": ">= 18.0.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    },
    "ios-testflight-internal": {
      "extends": "production",
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "channel": "testflight-internal"
    },
    "production-emulator": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759552514"
      }
    },
    "ios-testflight-internal": {
      "ios": {
        "ascAppId": "6759552514"
      }
    }
  }
}
